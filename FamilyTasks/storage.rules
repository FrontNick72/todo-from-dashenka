rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSpaceMember(spaceId) {
      return request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/spaces/$(spaceId)).data.memberUids;
    }

    match /spaces/{spaceId}/{allPaths=**} {
      allow read: if isSpaceMember(spaceId);
      allow write: if isSpaceMember(spaceId) &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.size < 5 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
